{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "redirects": [
    { "source": "/reports/huapengcheng", "destination": "/reports/huapengcheng/index.html", "permanent": false },
    { "source": "/reports/huapengcheng/", "destination": "/reports/huapengcheng/index.html", "permanent": false }
  ]
}
